# ===================================
# DATABASE CONFIGURATION
# ===================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-secure-password-here
DB_NAME=web_streaming
DB_SSLMODE=disable  # Production: require

# ===================================
# JWT & AUTHENTICATION
# ===================================
# WARNING: JWT_SECRET must be at least 32 characters in production
# Generate random: $(openssl rand -base64 32)
JWT_SECRET=dev-jwt-secret-change-in-production-min-32-chars
REFRESH_TOKEN_SECRET=dev-refresh-secret-change-in-production-min-32-chars
ACCESS_TOKEN_DURATION=15m
REFRESH_TOKEN_DURATION=168h  # 7 days

# ===================================
# SERVER CONFIGURATION
# ===================================
PORT=1010
GIN_MODE=debug  # debug, release

# ===================================
# CORS CONFIGURATION
# ===================================
# Comma-separated list of allowed origins
# Development: http://localhost:3000,http://localhost:5173
# Production: https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ===================================
# OPTIONAL: MONITORING & LOGGING
# ===================================
# LOG_LEVEL=info  # debug, info, warn, error
# METRICS_ENABLED=true
# TRACING_ENABLED=false

# ===================================
# OPTIONAL: RATE LIMITING
# ===================================
# Rate limits are configured in routes.go
# Example: "10-M" = 10 requests per minute
# Adjust values based on expected load